APP_NAME="Kindergarten ERP"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Asia/Kolkata

FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kindergarten_erp
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120

BROADCAST_CONNECTION=log

# Laravel Reverb / Pusher (real-time live stream switching)
# Set REVERB_ENABLED=true and run: php artisan reverb:start
REVERB_ENABLED=false
REVERB_APP_ID=kindergarten
REVERB_APP_KEY=kindergarten-key
REVERB_APP_SECRET=kindergarten-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_ENABLED=false
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# LiveKit WebRTC (built-in browser camera streaming — video does not pass through Laravel)
# Local dev: docker compose -f docker-compose.livekit.yml up -d  (from backend/)
# Or: powershell -File scripts/start-livekit.ps1
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=kindergarten-dev-livekit-secret-key-32chars
LIVEKIT_TOKEN_TTL=3600

FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# API requests per minute (per user/IP). Default: 1000 local, 300 production.
API_RATE_LIMIT=1000

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@littlestars.edu"
MAIL_FROM_NAME="${APP_NAME}"

# Razorpay keys are configured per-tenant in Admin → Settings → Payment Settings.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

SANCTUM_STATEFUL_DOMAINS=localhost,localhost:5173,127.0.0.1,127.0.0.1:5173

# SoftKatta licensing — filled by Install Wizard (POST /install/company-api). Site locked until install completes.
SOFTKATTA_LICENSING_ENABLED=true
SOFTKATTA_COMPANY_API_URL=https://api.softkatta.in/api/v1/company
SOFTKATTA_PUBLIC_API_KEY=
SOFTKATTA_API_SECRET=
SOFTKATTA_PRODUCT_SLUG=kindergarten
SOFTKATTA_PRODUCT_VERSION=1.0.0
SOFTKATTA_OFFLINE_GRACE_DAYS=1
SOFTKATTA_VERIFY_INTERVAL_HOURS=0
SOFTKATTA_VERIFY_INTERVAL_MINUTES=0
SOFTKATTA_TIMESTAMP_SKEW=300
SOFTKATTA_REQUIRE_HTTPS=true

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false
