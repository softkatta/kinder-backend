APP_NAME="Kindergarten ERP"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://kinder-api.softkatta.in

FRONTEND_URL=https://kinder.softkatta.in
CORS_ALLOWED_ORIGINS=https://kinder.softkatta.in,https://www.kinder.softkatta.in
SANCTUM_STATEFUL_DOMAINS=kinder.softkatta.in,www.kinder.softkatta.in,kinder-api.softkatta.in
SESSION_DOMAIN=.softkatta.in
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

# After deploy: php artisan config:clear
# If browser still shows CORS on 403: Hostinger hPanel → Security → ModSecurity → Off for kinder-api

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kindergarten_erp
DB_USERNAME=erp_user
DB_PASSWORD=

FILESYSTEM_DISK=local

QUEUE_CONNECTION=database
CACHE_STORE=database
SESSION_DRIVER=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@kinder.softkatta.in"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp / SMS — configure in Admin → Settings → Notifications (per-event channels).
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=

# Razorpay keys are configured in Admin → Settings → Payment Settings.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

REVERB_ENABLED=false
REVERB_APP_ID=kindergarten
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=https

LIVEKIT_URL=wss://livekit.yourschool.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600

API_RATE_LIMIT=300

# SoftKatta licensing — filled by Install Wizard on first deploy
# Product slug must match SoftKatta Admin → Product Integrations
SOFTKATTA_LICENSING_ENABLED=true
SOFTKATTA_COMPANY_API_URL=https://api.softkatta.in/api/v1/company
SOFTKATTA_PUBLIC_API_KEY=
SOFTKATTA_API_SECRET=
SOFTKATTA_PRODUCT_SLUG=nursery-school-management-software
SOFTKATTA_PRODUCT_VERSION=1.0.0
SOFTKATTA_OFFLINE_GRACE_DAYS=1
SOFTKATTA_VERIFY_INTERVAL_HOURS=0
SOFTKATTA_VERIFY_INTERVAL_MINUTES=0
SOFTKATTA_VERIFY_COALESCE_SECONDS=5
SOFTKATTA_TIMESTAMP_SKEW=300
SOFTKATTA_REQUIRE_HTTPS=true
