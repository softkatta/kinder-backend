APP_NAME="Kindergarten ERP"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://api.yourschool.com

FRONTEND_URL=https://www.yourschool.com
SANCTUM_STATEFUL_DOMAINS=yourschool.com,www.yourschool.com

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=kindergarten_erp
DB_USERNAME=erp_user
DB_PASSWORD=

FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=

QUEUE_CONNECTION=database
CACHE_STORE=redis
SESSION_DRIVER=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@yourschool.com"
MAIL_FROM_NAME="${APP_NAME}"

# WhatsApp / SMS — configure in Admin → Settings → Notifications (per-event channels).
# WHATSAPP_API_URL=
# WHATSAPP_API_TOKEN=

# Razorpay keys are configured in Admin → Settings → Payment Settings.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=

REVERB_ENABLED=false
REVERB_APP_ID=kindergarten
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=https

LIVEKIT_URL=wss://livekit.yourschool.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL=3600

API_RATE_LIMIT=300
